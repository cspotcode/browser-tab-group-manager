{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    // Any higher and esbuild doesn't downlevel the decorators
    "target": "ES2021",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Must be false to ensure using ES decorators, not legacy TS experimentalDecorators
    "experimentalDecorators": false,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  }
}
